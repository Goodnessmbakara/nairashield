# Copy to .dev.vars for local wrangler dev (never commit real secrets).

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
SESSION_SECRET=generate-a-long-random-string-at-least-32-chars
WORKER_URL=http://127.0.0.1:8787
FRONTEND_URL=http://127.0.0.1:4321

# ── Solana (required for Kamino withdraw/deposit) ─────────
# SOLANA_PRIVATE_KEY=
# RPC_URL=https://api.devnet.solana.com

# ── Agent policy (PRD market-make + Y_net) ────────────────
YIELD_APY=0.08
TRADE_SIZE_USDC=10
MIN_EDGE=0.01
MAKER_MARGIN=0.02
EVENT_HORIZON_HOURS=2
MAX_OPEN_POSITIONS=3

# ── Integrations (required for live ticks — no mock fallback) ─
# TXLINE_API_URL=
# TXLINE_API_KEY=
# BETDEX_API_URL=https://prod.api.btdx.io
# BETDEX_API_KEY=
