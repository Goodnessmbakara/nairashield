# Copy to .dev.vars for local wrangler dev (never commit real secrets).
# Agent policy (yield APY, trade size, margins, etc.) is NOT here —
# edit src/agent/config.ts → AGENT_POLICY.

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
WORKER_URL=http://127.0.0.1:8787
FRONTEND_URL=http://127.0.0.1:4321

# ── Solana (agent wallet — signs Kamino + Jupiter txs) ────
# SOLANA_PRIVATE_KEY=
# Public api.*.solana.com blocks Cloudflare Worker IPs (403) — use Helius/QuickNode.
# RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# When TxLINE is on txline-dev, verify needs a *devnet* RPC (Kamino stays on mainnet RPC_URL):
# TXLINE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Integrations (required for live ticks — no mock fallback) ─
# TxLINE: activate via scripts/txline-activation/activate.ts (needs mainnet SOL)
# TXLINE_API_URL=https://txline.txodds.com
# TXLINE_API_KEY=

# Jupiter Predict (execution venue): free key from portal.jup.ag/api-keys
# JUPITER_API_KEY=
# JUPITER_MARKET_MAP=

# Kamino (mainnet — must match mainnet RPC + mainnet USDC)
# KAMINO_MARKET_PUBKEY=7u3HeHxYDLhnCoErrtycNokbQYbWGzLs6JSDqGAv5PfF
# USDC_MINT_PUBKEY=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# FossaPay (managed Solana USDC deposit wallets — dashboard.fossapay.com)
# FOSSAPAY_API_KEY=fp_test_sk_...
# FOSSAPAY_WEBHOOK_SECRET=
# FOSSAPAY_API_URL=https://api-production.fossapay.com/api/v1

# Read-only agent SDK / MCP (`GET /v1/*`) — openssl rand -hex 32
# RETEGOL_AGENT_KEY=
# Cron tick trigger: GET /agent/run?key=…
# CRON_SECRET=
