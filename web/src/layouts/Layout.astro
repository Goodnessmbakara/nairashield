---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** Preload hero atmosphere image (landing only) */
  preloadHeroBg?: boolean;
  /** Legal disclaimer footer — landing page only, never inside the app */
  legalFooter?: boolean;
}

const SITE = "https://retegol.pages.dev";
const DEFAULT_DESCRIPTION =
  "Sports capital often sits idle between plays. Retegol keeps it in yield and only deploys when a live market clears the cost.";

const {
  title = "Retegol",
  description = DEFAULT_DESCRIPTION,
  preloadHeroBg = false,
  legalFooter = false,
} = Astro.props;

const pageTitle = title === "Retegol" ? "Retegol — Capital that never sits still" : title;
const ogImage = `${SITE}/og.png`;
const canonical = new URL(Astro.url.pathname, SITE).toString();
// Bust stale N-logo caches in browsers / iMessage / WhatsApp
const iconV = "2";
---

<!doctype html>
<html lang="en" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Prefer SVG R mark; PNG/ICO for older clients. Cache-bust so shared links drop the old N. -->
    <link rel="icon" href={`/favicon.svg?v=${iconV}`} type="image/svg+xml" />
    <link rel="icon" href={`/favicon.png?v=${iconV}`} type="image/png" sizes="32x32" />
    <link rel="shortcut icon" href={`/favicon.ico?v=${iconV}`} />
    <link rel="apple-touch-icon" href={`/brand/apple-touch-icon.png?v=${iconV}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Retegol" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Retegol — Capital that never sits still" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Retegol — Capital that never sits still" />

    {preloadHeroBg && <link rel="preload" as="image" href="/bg.jpg" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Sora:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-background font-sans text-foreground antialiased">
    <div class="min-h-dvh flex flex-col bg-background">
      <main class="flex-grow">
        <slot />
      </main>
      
      <!-- Hackathon Legal Compliance Disclaimer Footer (landing only) -->
      {legalFooter && <footer class="mt-auto border-t border-divider bg-content2 py-8 text-center text-xs text-default-500">
        <div class="container mx-auto px-4 max-w-4xl space-y-4">
          <p class="font-semibold text-foreground/80">⚖️ Legal & Compliance Disclaimer</p>
          <p>
            <strong>IMPORTANT:</strong> This project is an experimental hackathon submission for the Superteam Earn "Trading Tools and Agents" track. It is for educational and demonstration purposes only.
          </p>
          <p>
            Retegol is a technical demonstration of algorithmic trading concepts and autonomous agents using Solana and the TxLINE API. It does <strong>not</strong> constitute financial advice, and it is <strong>not</strong> an endorsement of gambling or illegal betting.
          </p>
          <p>
            Users and developers deploying this software are solely responsible for ensuring their use complies with all applicable laws and regulations in their jurisdiction, including but not limited to gambling, gaming, financial, consumer protection, and securities laws. TxLINE and Superteam Earn do not endorse or authorize illegal betting, wagering, or any illicit financial activity.
          </p>
        </div>
      </footer>}
    </div>
  </body>
</html>
