---
import "../styles/global.css";

interface Props {
  title?: string;
  /** Preload hero atmosphere image (landing only) */
  preloadHeroBg?: boolean;
}
const { title = "NairaShield", preloadHeroBg = false } = Astro.props;
---

<!doctype html>
<html lang="en" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Sports capital often sits idle between plays. NairaShield keeps it in yield and only deploys when a live market clears the cost."
    />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/brand/apple-touch-icon.png" />
    {preloadHeroBg && <link rel="preload" as="image" href="/bg.jpg" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Sora:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background font-sans text-foreground antialiased">
    <div class="min-h-dvh flex flex-col bg-background">
      <main class="flex-grow">
        <slot />
      </main>
      
      <!-- Hackathon Legal Compliance Disclaimer Footer -->
      <footer class="mt-auto border-t border-divider bg-content2 py-8 text-center text-xs text-default-500">
        <div class="container mx-auto px-4 max-w-4xl space-y-4">
          <p class="font-semibold text-foreground/80">⚖️ Legal & Compliance Disclaimer</p>
          <p>
            <strong>IMPORTANT:</strong> This project is an experimental hackathon submission for the Superteam Earn "Trading Tools and Agents" track. It is for educational and demonstration purposes only.
          </p>
          <p>
            NairaShield is a technical demonstration of algorithmic trading concepts and autonomous agents using Solana and the TxLINE API. It does <strong>not</strong> constitute financial advice, and it is <strong>not</strong> an endorsement of gambling or illegal betting.
          </p>
          <p>
            Users and developers deploying this software are solely responsible for ensuring their use complies with all applicable laws and regulations in their jurisdiction, including but not limited to gambling, gaming, financial, consumer protection, and securities laws. TxLINE and Superteam Earn do not endorse or authorize illegal betting, wagering, or any illicit financial activity.
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>
